# ─────────────────────────────────────────────
#  Coco and Luna — Dashboard (configuração)
#  Copie este arquivo para ".env" e preencha.
#  NUNCA suba o .env para o GitHub (já está no .gitignore).
# ─────────────────────────────────────────────

# Porta do servidor
PORT=3000

# Cada quantos minutos buscar dados novos dos canais
SYNC_INTERVAL_MINUTES=15

# Fuso da loja (minutos em relação ao UTC). Brasil = -180
STORE_OFFSET_MINUTES=-180

# ── SHOPIFY ──────────────────────────────────
# Domínio .myshopify.com da loja
SHOPIFY_STORE=ebb5cd.myshopify.com
# Token de Admin API de um "app personalizado" (custom app) com os escopos:
# read_orders, read_products, read_reports
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
# Versão da Admin API (pode atualizar com o tempo)
SHOPIFY_API_VERSION=2025-07

# ── SHOPEE (Open Platform) ───────────────────
# Do console open.shopee.com (sua conta Open Shopee)
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
# ID da sua loja (sai depois de autorizar)
SHOPEE_SHOP_ID=
# URL de retorno cadastrada no app (precisa bater exatamente).
# Em produção, algo como https://SEU-DOMINIO/shopee/callback
SHOPEE_REDIRECT_URL=http://localhost:3000/shopee/callback
# Use 1 para ambiente de produção da Shopee, 0 para sandbox/test
SHOPEE_PRODUCTION=1

# ── MERCADO LIVRE ────────────────────────────
# ID e Secret do app criado em https://developers.mercadolivre.com.br/
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# URL de retorno cadastrada no app (precisa bater exatamente).
# Em produção, algo como https://SEU-DOMINIO/mercadolivre/callback
ML_REDIRECT_URL=http://localhost:3000/mercadolivre/callback
