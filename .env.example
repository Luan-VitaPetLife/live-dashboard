# ─────────────────────────────────────────────
#  Coco and Luna — Dashboard (configuração)
#  Copie este arquivo para ".env" e preencha.
#  NUNCA suba o .env para o GitHub (já está no .gitignore).
# ─────────────────────────────────────────────

# Porta do servidor
PORT=3000

# Cada quantos minutos buscar dados novos dos canais
SYNC_INTERVAL_MINUTES=15

# Fuso da loja (minutos em relação ao UTC). Brasil = -180
STORE_OFFSET_MINUTES=-180

# ── SHOPIFY ──────────────────────────────────
# Domínio .myshopify.com da loja
SHOPIFY_STORE=ebb5cd.myshopify.com
# Token de Admin API de um "app personalizado" (custom app) com os escopos:
# read_orders, read_products, read_reports
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
# Versão da Admin API (pode atualizar com o tempo)
SHOPIFY_API_VERSION=2025-07

# ── SHOPEE (Open Platform) ───────────────────
# Do console open.shopee.com (sua conta Open Shopee)
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
# ID da sua loja (sai depois de autorizar)
SHOPEE_SHOP_ID=
# URL de retorno cadastrada no app (precisa bater exatamente).
# Em produção, algo como https://SEU-DOMINIO/shopee/callback
SHOPEE_REDIRECT_URL=http://localhost:3000/shopee/callback
# Use 1 para ambiente de produção da Shopee, 0 para sandbox/test
SHOPEE_PRODUCTION=1

# ── MERCADO LIVRE ────────────────────────────
# ID e Secret do app criado em https://developers.mercadolivre.com.br/
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# URL de retorno cadastrada no app (precisa bater exatamente).
# Em produção, algo como https://SEU-DOMINIO/mercadolivre/callback
ML_REDIRECT_URL=https://live-dashboard-vitapetlife.up.railway.app/mercadolivre/callback

# ── SHOPIFY EUA ───────────────────────────────
# Domínio .myshopify.com da loja US
SHOPIFY_US_STORE=vita-pet-life.myshopify.com
# Token do custom app US (escopos: read_orders, read_products, read_reports, read_analytics)
SHOPIFY_US_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx

# ── META ADS ─────────────────────────────────
# ID e Secret do app em developers.facebook.com
META_APP_ID=
META_APP_SECRET=
# Token de acesso de longa duração (System User) — usado para BR e EUA
META_ACCESS_TOKEN=
# Conta de anúncios BR — Coco and Luna (sem prefixo act_)
META_AD_ACCOUNT_ID=
# Conta de anúncios EUA — Vita Pet Life (sem prefixo act_)
META_US_AD_ACCOUNT_ID=826249215807271

# ── AMAZON EUA (SP-API) ───────────────────────
# Credenciais do app LWA registrado em sellercentral.amazon.com
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
# Refresh token obtido ao autorizar o app para sua conta vendedor US
AMAZON_REFRESH_TOKEN=

# ── AMAZON BR (SP-API) ────────────────────────
# Credenciais do app LWA registrado em sellercentral.amazon.com.br
# Pode ser o mesmo app do US se registrado em ambas as regiões,
# ou um app separado — use as chaves específicas da conta vendedor BR.
AMAZON_BR_CLIENT_ID=
AMAZON_BR_CLIENT_SECRET=
# Refresh token obtido ao autorizar o app para sua conta vendedor BR
AMAZON_BR_REFRESH_TOKEN=

# ── GOOGLE ADS (EUA) ──────────────────────────
# Projeto criado em console.cloud.google.com com a API "Google Ads API" ativada.
# OAuth Client ID do tipo "Web application"
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# URL de retorno cadastrada no OAuth Client (precisa bater exatamente).
# Em produção, algo como https://SEU-DOMINIO/googleads/callback
GOOGLE_ADS_REDIRECT_URL=https://live-dashboard-vitapetlife.up.railway.app/googleads/callback
# Developer Token gerado no Google Ads API Center (precisa de aprovação "Basic access"
# para consultar contas reais — o nível inicial "Test accounts" só funciona com contas de teste)
GOOGLE_ADS_DEVELOPER_TOKEN=
# Customer ID da conta "Coco and Luna" (só dígitos, sem hífen). Ex: 134-411-4329 → 1344114329
GOOGLE_ADS_CUSTOMER_ID=1344114329
# Só preencher se o Developer Token foi gerado sob uma conta gerenciadora (MCC) —
# nesse caso, use o Customer ID da MCC aqui (sem hífen)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── AMAZON COMPARTILHADO (EUA + BR) ──────────
# IAM User com permissão sts:AssumeRole no role abaixo
AMAZON_AWS_ACCESS_KEY=
AMAZON_AWS_SECRET_KEY=
# ARN do IAM Role com política de acesso à SP-API
AMAZON_ROLE_ARN=arn:aws:iam::354674816862:role/SellingPartnerAPIRole
